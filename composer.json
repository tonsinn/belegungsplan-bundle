{
    "name": "tonsinn/belegungsplan-bundle",
    "type": "contao-bundle",
    "keywords": ["contao", "contao-bundle", "bundle", "belegungsplan", "contao 5"],
    "description": "Contao 5 Belegungspläne erstellen",
    "license": "LGPL-3.0-or-later",
    "authors": [
        {
            "name": "Jan Karai",
            "homepage": "https://www.sachsen-it.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "contao/core-bundle": "^5.7",
        "contao/manager-plugin": "^2.0"
    },
    "conflict": {
        "contao/core": "*"
    },
    "autoload": {
        "psr-4": {
            "Tonsinn\\BelegungsplanBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tonsinn\\BelegungsplanBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist"
    },
    "extra": {
        "contao-manager-plugin": "Tonsinn\\BelegungsplanBundle\\ContaoManager\\Plugin"
    }
}
